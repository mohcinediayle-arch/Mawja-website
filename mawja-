<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MAWJA — كتالوج الخدمات</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Tajawal:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #C9A84C;
    --gold-light: #E8C97A;
    --gold-dark: #8B6914;
    --black: #080808;
    --black-mid: #111111;
    --black-light: #1A1A1A;
    --white: #F5F0E8;
    --white-dim: #B8AFA0;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--black);
    font-family: 'Tajawal', sans-serif;
    color: var(--white);
    min-height: 100vh;
    padding: 40px 20px;
  }

  /* ===== INTRO CARD (Cover) ===== */
  .cover-card {
    width: 800px;
    height: 800px;
    margin: 0 auto 60px;
    background: var(--black-mid);
    border: 1px solid rgba(201,168,76,0.25);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .cover-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 60% at 50% 0%, rgba(201,168,76,0.12) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 80% 80%, rgba(201,168,76,0.06) 0%, transparent 60%);
  }

  .cover-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }

  .cover-ornament {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0; left: 0;
    pointer-events: none;
  }

  .cover-ornament .corner {
    position: absolute;
    width: 80px;
    height: 80px;
    border-color: rgba(201,168,76,0.3);
    border-style: solid;
  }
  .corner.tl { top: 20px; right: 20px; border-width: 1px 1px 0 0; }
  .corner.tr { top: 20px; left: 20px; border-width: 1px 0 0 1px; }
  .corner.bl { bottom: 20px; right: 20px; border-width: 0 1px 1px 0; }
  .corner.br { bottom: 20px; left: 20px; border-width: 0 0 1px 1px; }

  .cover-wave {
    font-family: 'Playfair Display', serif;
    font-size: 96px;
    font-weight: 900;
    line-height: 1;
    background: linear-gradient(135deg, var(--gold-light), var(--gold), var(--gold-dark));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 8px;
    position: relative;
    z-index: 1;
    letter-spacing: -2px;
  }

  .cover-arabic {
    font-family: 'Tajawal', sans-serif;
    font-size: 28px;
    font-weight: 300;
    color: var(--gold);
    letter-spacing: 8px;
    margin-bottom: 32px;
    position: relative;
    z-index: 1;
  }

  .cover-divider {
    width: 120px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin: 0 auto 32px;
    position: relative;
    z-index: 1;
  }
  .cover-divider::before {
    content: '✦';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: var(--gold);
    font-size: 12px;
    background: var(--black-mid);
    padding: 0 8px;
  }

  .cover-tagline {
    font-size: 16px;
    font-weight: 300;
    color: var(--white-dim);
    letter-spacing: 2px;
    position: relative;
    z-index: 1;
    line-height: 1.8;
  }

  .cover-tagline strong {
    color: var(--white);
    font-weight: 500;
  }

  .cover-badge {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 12px;
    z-index: 1;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background: var(--gold);
    border-radius: 50%;
  }

  .badge-text {
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--white-dim);
    text-transform: uppercase;
  }

  /* ===== SERVICE CARDS ===== */
  .cards-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 800px;
    margin: 0 auto 24px;
  }

  .cards-grid-single {
    max-width: 800px;
    margin: 0 auto;
  }

  .service-card {
    background: var(--black-mid);
    border: 1px solid rgba(201,168,76,0.15);
    position: relative;
    overflow: hidden;
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
    padding: 40px;
    transition: border-color 0.3s;
  }

  .service-card:hover {
    border-color: rgba(201,168,76,0.4);
  }

  .service-card::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.4s;
    background: radial-gradient(ellipse 70% 70% at 50% 0%, rgba(201,168,76,0.08) 0%, transparent 70%);
  }
  .service-card:hover::before { opacity: 1; }

  /* Top line accent */
  .service-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .service-card:hover::after { opacity: 1; }

  /* BG Number */
  .card-bg-num {
    position: absolute;
    bottom: -20px;
    left: -10px;
    font-family: 'Playfair Display', serif;
    font-size: 160px;
    font-weight: 900;
    color: rgba(201,168,76,0.04);
    line-height: 1;
    user-select: none;
    pointer-events: none;
  }

  .card-icon-wrap {
    width: 52px;
    height: 52px;
    border: 1px solid rgba(201,168,76,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    position: relative;
    z-index: 1;
    flex-shrink: 0;
  }

  .card-icon {
    font-size: 22px;
  }

  .card-number {
    position: absolute;
    top: 40px;
    left: 40px;
    font-family: 'Playfair Display', serif;
    font-size: 11px;
    color: var(--gold-dark);
    letter-spacing: 3px;
  }

  .card-content {
    position: relative;
    z-index: 1;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-title {
    font-family: 'Tajawal', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 14px;
    line-height: 1.3;
  }

  .card-divider {
    width: 40px;
    height: 1px;
    background: var(--gold);
    margin-bottom: 16px;
    flex-shrink: 0;
  }

  .card-desc {
    font-size: 14px;
    font-weight: 300;
    color: var(--white-dim);
    line-height: 1.8;
    flex: 1;
  }

  .card-features {
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--white-dim);
  }

  .feature-dot {
    width: 4px;
    height: 4px;
    background: var(--gold);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .card-price {
    margin-top: 24px;
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .price-from {
    font-size: 11px;
    color: var(--white-dim);
    letter-spacing: 2px;
  }

  .price-amount {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    font-weight: 700;
    background: linear-gradient(135deg, var(--gold-light), var(--gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .price-unit {
    font-size: 12px;
    color: var(--white-dim);
  }

  /* Wide card (last one) */
  .service-card.wide {
    aspect-ratio: auto;
    min-height: 300px;
  }

  .wide .card-content {
    flex-direction: row;
    align-items: center;
    gap: 60px;
  }

  .wide .card-left {
    flex: 1;
  }

  .wide .card-right {
    flex: 1;
  }

  .wide .card-features {
    margin-top: 0;
  }

  /* ===== CTA CARD ===== */
  .cta-card {
    width: 800px;
    height: 400px;
    margin: 24px auto 0;
    background: var(--black-mid);
    border: 1px solid rgba(201,168,76,0.2);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    flex-direction: column;
    gap: 20px;
  }

  .cta-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 80% at 50% 100%, rgba(201,168,76,0.1) 0%, transparent 65%);
  }

  .cta-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }

  .cta-label {
    font-size: 11px;
    letter-spacing: 5px;
    color: var(--gold);
    text-transform: uppercase;
    position: relative;
    z-index: 1;
  }

  .cta-title {
    font-family: 'Playfair Display', serif;
    font-size: 42px;
    font-weight: 700;
    color: var(--white);
    position: relative;
    z-index: 1;
    line-height: 1.2;
  }

  .cta-title span {
    background: linear-gradient(135deg, var(--gold-light), var(--gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cta-subtitle {
    font-size: 15px;
    color: var(--white-dim);
    font-weight: 300;
    position: relative;
    z-index: 1;
  }

  .cta-contact {
    display: flex;
    align-items: center;
    gap: 16px;
    position: relative;
    z-index: 1;
    margin-top: 8px;
  }

  .cta-phone {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    color: var(--gold-light);
    letter-spacing: 2px;
  }

  .cta-sep {
    width: 1px;
    height: 24px;
    background: rgba(201,168,76,0.3);
  }

  .cta-handle {
    font-size: 14px;
    color: var(--white-dim);
    letter-spacing: 1px;
  }

  /* Print helper */
  @media print {
    body { background: #080808; -webkit-print-color-adjust: exact; }
  }
</style>
</head>
<body>

<!-- ========== COVER CARD ========== -->
